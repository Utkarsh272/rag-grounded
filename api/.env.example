# Copy this to .env and fill in your values
# Never commit .env — it's in .gitignore

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── LLM providers ─────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-key-here            # free at console.groq.com
ANTHROPIC_API_KEY=your-anthropic-key-here  # for final demo / screenshots only
LLM_PROVIDER=groq                          # groq | anthropic

# ── Embeddings ────────────────────────────────────────────────────────────────
JINA_API_KEY=your-jina-key-here            # free at jina.ai (1M tokens on signup)

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Verification thresholds (optional — defaults shown) ───────────────────────
ABSTAIN_RERANK_THRESHOLD=-6.0
ABSTAIN_JACCARD_THRESHOLD=0.08
CLAIM_CONFIDENCE_THRESHOLD=0.50
