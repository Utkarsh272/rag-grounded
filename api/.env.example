# Copy this to .env and fill in your values
# Never commit .env — it's in .gitignore

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

OPENAI_API_KEY=your-openai-key-here       # only needed for embeddings if switching from local model
GROQ_API_KEY=your-groq-key-here           # free at console.groq.com
ANTHROPIC_API_KEY=your-anthropic-key-here # for final demo only

LLM_PROVIDER=groq                         # groq | anthropic | openai
